# Node.js / NestJS specific ignores for the Backend service

# Dependencies
node_modules/

# Compiled TypeScript/JavaScript output
dist/

# Environment variables - DO NOT COMMIT .env FILES!
.env
.env.*
!.env.example

# Package manager logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Test coverage reports
coverage/

# Package caches
.npm
.pnp.*